# =================================================================
#  .env.example — Price App
#  Copia este archivo a .env y ajusta los valores
# =================================================================


# -----------------------------------------------------------------
#  MODO DE CONEXIÓN A FIREBIRD
#
#  Opción A (por defecto) — Firebird ya instalado en el host
#    El contenedor price_server se conecta al servidor Windows.
#    No es necesario cambiar nada más.
#
#  Opción B — Firebird gestionado por Docker
#    Descomenta COMPOSE_PROFILES y DB_FILE_PATH, y cambia
#    DB_HOST a "firebird".
# -----------------------------------------------------------------

# COMPOSE_PROFILES=firebird


# -----------------------------------------------------------------
#  BASE DE DATOS FIREBIRD
# -----------------------------------------------------------------

# Dirección del servidor Firebird
#   Opción A → host.docker.internal  (servidor en el propio PC)
#   Opción B → firebird              (contenedor Docker)
DB_HOST=host.docker.internal
DB_PORT=3050

# Ruta al archivo .gdb tal como la ve el servidor Firebird
#   Opción A → ruta Windows con barras invertidas
#   Opción B → /firebird/data/prices.gdb
DB_DATABASE=C:\ruta\a\tu\archivo.GDB

# Credenciales de Firebird
DB_USER=SYSDBA
DB_PASSWORD=masterkey

# (Solo Opción B) Ruta en el host para montar el .gdb en el contenedor
# Usa barras inclinadas / aunque estés en Windows
# DB_FILE_PATH=C:/ruta/a/tu/archivo.GDB


# -----------------------------------------------------------------
#  API — PRICE SERVER
# -----------------------------------------------------------------

# Puerto expuesto en el host
SERVER_PORT=3000


# -----------------------------------------------------------------
#  WEB — PRICE DISPLAY
# -----------------------------------------------------------------

# Puerto expuesto en el host
DISPLAY_PORT=80

# Nota: no es necesario configurar la URL de la API.
# nginx redirige automáticamente las peticiones /api/ al contenedor
# price_server, por lo que la web funciona desde cualquier IP.
